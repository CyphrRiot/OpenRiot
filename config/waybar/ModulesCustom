	// ----- OpenRiot theme specific module override (this was in `/config`)
	"custom/arch": {
		"format": "󰀻",
		"on-click": "fuzzel",
		"on-click-right": "pkill fuzzel",
		"tooltip": true,
		"tooltip-format": "Left-click: App Launcher | Right-click: Close Launcher"
	},

    "custom/openriot-update": {
    	"exec": "$HOME/.local/share/openriot/config/waybar/scripts/openriot-update.sh",
    	"return-type": "json",
    	"interval": 300,
    	"on-click": "$HOME/.local/share/openriot/config/waybar/scripts/openriot-update.sh --click",
    	"tooltip": true,
    },

    // Battery status via apm(8) — OpenBSD native
    "custom/battery": {
    	"format": "{}",
    	"return-type": "json",
    	"interval": 30,
    	"exec": "$HOME/.local/share/openriot/config/waybar/scripts/waybar-battery.sh",
    	"on-click-right": "$HOME/.local/share/openriot/install/openriot --power-menu",
    	"tooltip": true
    },
