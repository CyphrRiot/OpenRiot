    // },

    "custom/lock": {
    	"format": "󰌾",
    	"on-click": "swaylock -f",
    	"tooltip": true,
    	"tooltip-format": "󰷛 Screen Lock",
    },

    "custom/rec-dot": {
    	"format": "{}",
    	"return-type": "json",
    	"interval": 2,
    	"exec": "$HOME/.local/share/openriot/config/waybar/scripts/recording-indicator.sh",
    	"on-click": "$HOME/.local/share/openriot/config/waybar/scripts/recording-indicator.sh --click",
    	"tooltip": true
    },

    // DISABLED: --waybar-pomodoro and --pomodoro-click are not implemented in the openriot binary
    // "custom/tomato-timer": {
    // 	"format": "{}",
