    // Custom CPU meter showing aggregate usage across all cores
    "custom/cpu-aggregate": {
    	"format": "{}",
    	"return-type": "json",
    	"interval": 2,
    	"exec": "$HOME/.local/share/openriot/config/waybar/scripts/waybar-cpu.sh",
    	"on-click": "foot -e htop",
    	"on-click-right": "foot -e htop",
    	"tooltip": true
    },

    "custom/power": {
    	"format": " ⏻ ",
    	"on-click": "$HOME/.local/share/openriot/install/openriot --power-menu",
    	"tooltip": false
    },

    // Custom temperature module with visual bar indicators
    "custom/temp-bar": {
    	"format": "{}",
    	"return-type": "json",
    	"interval": 10,
    	"exec": "$HOME/.local/share/openriot/config/waybar/scripts/waybar-temp.sh",
    	"on-click": "foot -e htop",
    	"on-click-right": "foot -e htop",
    	"tooltip": true
    },

    // Custom volume module with visual bar indicators
    "custom/volume-bar": {
    	"format": "{}",
    	"return-type": "json",
    	"interval": 1,
    	"exec": "$HOME/.local/share/openriot/config/waybar/scripts/waybar-volume.sh",
    	"on-click": "$HOME/.local/share/openriot/install/openriot --volume toggle",
    	"on-scroll-up": "$HOME/.local/share/openriot/install/openriot --volume inc",
    	"on-scroll-down": "$HOME/.local/share/openriot/install/openriot --volume dec",
    	"tooltip": true
    },

    // Accurate memory module (Total - Free via vmstat)
    "custom/memory-accurate": {
    	"format": "{}",
    	"return-type": "json",
    	"interval": 5,
    	"exec": "$HOME/.local/share/openriot/config/waybar/scripts/waybar-memory.sh",
    	"on-click": "foot -e htop",
    	"on-click-right": "foot -e htop",
    	"tooltip": true
    },
    // Separators
    "custom/separator#dot": {
    	"format": "•",
    	"interval": "once",
    	"tooltip": false
    },
    "custom/separator#dot-line": {
    	"format": "",
    	"interval": "once",
    	"tooltip": false
    },
    "custom/separator#line": {
    	"format": "|",
    	"interval": "once",
    	"tooltip": false
    },
    "custom/separator#line-tray": {
    	"format": "|",
    	"interval": "once",
    	"tooltip": false
    },
    "custom/separator#blank": {
    	"format": "",
    	"interval": "once",
    	"tooltip": false
    },
    "custom/separator#blank_2": {
    	"format": "  ",
    	"interval": "once",
    	"tooltip": false
    },
    "custom/separator#blank_3": {
    	"format": "   ",
    	"interval": "once",
    	"tooltip": false
    },
    "custom/separator#tight": {
    	"format": " ",
    	"interval": "once",
    	"tooltip": false
    },
    "custom/arrow1": {
    	"format": "",
    	"tooltip": false
    },

    "custom/arrow2": {
    	"format": "",
    	"tooltip": false
    },

    "custom/arrow3": {
    	"format": "",
    	"tooltip": false
    },

    "custom/arrow4": {
