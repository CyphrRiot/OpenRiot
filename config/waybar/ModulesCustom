	// This was in `/UserModules`:
	// "custom/wireguard": {
    //     "exec": "$HOME/.config/waybar/scripts/wireguard-status.sh",
    //     "return-type": "json",
    //     "interval": 5,
    //     "on-click": "$HOME/.config/waybar/scripts/wireguard-click.sh left",
    //     "on-click-right": "$HOME/.config/waybar/scripts/wireguard-click.sh right",
    //     "tooltip": true
    // },
    "custom/wireguard": {
    	"format": "{}",
    	"return-type": "json",
    	"interval": 300,
        "restart-interval": 60,
        "exec-if": "command -v wg && ifconfig >/dev/null 2>&1",
    	"exec": "$HOME/.local/share/openriot/config/waybar/scripts/wireguard-status.sh",
    	"on-click": "$HOME/.local/share/openriot/config/waybar/scripts/wireguard-click.sh left",
    	"on-click-right": "$HOME/.local/share/openriot/config/waybar/scripts/wireguard-click.sh right",
    	"tooltip": true
    },
    "custom/weather-emoji": {
    	"format": "{}",
    	"interval": 600,
    	"exec": "$HOME/.local/share/openriot/config/waybar/scripts/weather-emoji-plain.sh",
    	"tooltip": true
    },

    // Custom network module - replaces built-in to prevent crashes on WiFi flaps
    "custom/network": {
    	"format": "{}",
    	"return-type": "json",
    	"interval": 300,
    	"exec": "$HOME/.local/share/openriot/config/waybar/scripts/waybar-network",
    	"on-click": "$HOME/.local/share/openriot/config/waybar/scripts/wifi-selector.sh",
    	"tooltip": true
    }
}
