#!/bin/sh
# OpenRiot - Waybar Network Status
# OpenBSD compatible — uses ifconfig(8) instead of Linux ip/iw

# Detect active wireless interface (em0, bge0, iwx0, etc.)
get_wifi_interface() {
    ifconfig | awk '/^[a-z]/ { iface=$1 } /ieee80211/ { print iface; exit }'
}

# Detect active ethernet interface
get_eth_interface() {
    ifconfig | awk '/^[a-z]/ { iface=$1 } /status: active/ && iface !~ /lo|vlan|enc|pflog|tun|wg/ { print iface; exit }'
}

# Get WiFi signal strength and SSID via ifconfig
get_wifi() {
    iface="$1"
    info=$(ifconfig "$iface" 2>/dev/null)

    # Check if connected
    ssid=$(printf '%s' "$info" | grep -oE 'nwid [^ ]+' | awk '{print $2}')
    if [ -z "$ssid" ]; then
        printf '{"text":"󰤙","tooltip":"WiFi disconnected","class":"disconnected"}\n'
        return
    fi

    # Get signal strength (in dBm)
    signal=$(printf '%s' "$info" | grep -oE 'signal [-0-9]+' | awk '{print $2}')

    if [ -n "$signal" ]; then
        # Convert dBm to percentage: -50dBm=100%, -100dBm=0%
        percent=$(awk -v s="$signal" 'BEGIN {
            p = int((s + 100) * 2)
            if (p > 100) p = 100
            if (p < 0) p = 0
            print p
        }')
    else
        percent=50
    fi

    # Choose icon by signal strength
    if [ "$percent" -ge 70 ]; then
        icon="󰤨"
    elif [ "$percent" -ge 50 ]; then
        icon="󰤥"
    elif [ "$percent" -ge 30 ]; then
        icon="󰤢"
    elif [ "$percent" -ge 20 ]; then
        icon="󰤟"
    else
        icon="󰤯"
    fi

    printf '{"text":"%s","tooltip":"WiFi: %s (%d%%)","class":"network"}\n' \
        "$icon" "$ssid" "$percent"
}

# Get ethernet status
get_ethernet() {
    iface="$1"
    printf '{"text":"󰈁","tooltip":"Ethernet: %s (active)","class":"network"}\n' "$iface"
}

# Main: check ethernet first, then WiFi
eth=$(get_eth_interface)
wifi=$(get_wifi_interface)

if [ -n "$eth" ]; then
    get_ethernet "$eth"
elif [ -n "$wifi" ]; then
    get_wifi "$wifi"
else
    printf '{"text":"󰈂","tooltip":"No network connection","class":"disconnected"}\n'
fi
